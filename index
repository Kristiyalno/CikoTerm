<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ÇikoTerm — Je Pète'nin Termometresi</title>
<link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=JetBrains+Mono:wght@300;400;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

:root {
  --bg: #F7F2EA;
  --bg2: #EDE5D5;
  --ink: #1C1008;
  --choc: #3D1C00;
  --gold: #B8860B;
  --amber: #D4920A;
  --cream: #FDF8F0;
  --warm-gray: #8A7A6A;
  --border: rgba(61,28,0,0.15);
  --red-zone: #C0392B;
  --blue-zone: #2471A3;
  --green-zone: #1E8449;
  --perfect-zone: #B8860B;
}

body {
  font-family: 'Lato', sans-serif;
  background: var(--bg);
  color: var(--ink);
  min-height: 100vh;
}

/* ── NAV ── */
nav {
  background: var(--choc);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  height: 56px;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 12px rgba(0,0,0,0.3);
}

.nav-brand {
  font-family: 'Libre Baskerville', serif;
  color: #F5D78E;
  font-size: 1.1rem;
  letter-spacing: 2px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.nav-brand .dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #F5D78E;
  animation: blink 2s ease infinite;
}

.tab-bar {
  display: flex;
  gap: 4px;
}

.tab-btn {
  background: transparent;
  border: none;
  color: rgba(245,215,142,0.6);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 8px 20px;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
}

.tab-btn.active {
  color: #F5D78E;
  border-bottom-color: #F5D78E;
}

.tab-btn:hover:not(.active) {
  color: rgba(245,215,142,0.9);
}

/* ── PAGES ── */
.page { display: none; }
.page.active { display: block; }

/* ══════════════════════════════
   PAGE 1: THERMOMETER
══════════════════════════════ */
.thermo-page {
  padding: 40px;
  max-width: 1100px;
  margin: 0 auto;
}

.page-header {
  margin-bottom: 36px;
}

.page-header h2 {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.6rem;
  color: var(--choc);
  font-weight: 700;
}

.page-header p {
  color: var(--warm-gray);
  font-size: 0.9rem;
  margin-top: 4px;
  font-style: italic;
}

.thermo-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 32px;
  align-items: start;
}

/* ── SVG THERMOMETER ── */
.thermo-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
  box-shadow: 0 4px 24px rgba(61,28,0,0.08);
}

.thermo-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--warm-gray);
  align-self: flex-start;
}

.thermo-svg-wrap {
  position: relative;
  width: 120px;
}

/* Big digital readout */
.big-temp {
  font-family: 'JetBrains Mono', monospace;
  font-size: 3.2rem;
  font-weight: 600;
  color: var(--choc);
  letter-spacing: -2px;
  line-height: 1;
  display: flex;
  align-items: flex-start;
  gap: 2px;
}

.big-temp .unit {
  font-size: 1.4rem;
  font-weight: 300;
  margin-top: 6px;
  color: var(--warm-gray);
}

.phase-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  border-radius: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  font-weight: 600;
  transition: all 0.5s ease;
  width: 100%;
  justify-content: center;
}

.phase-chip .chip-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  animation: blink 1.5s ease infinite;
}

/* ── CONTROLS ── */
.controls-area {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.panel {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  box-shadow: 0 2px 12px rgba(61,28,0,0.05);
}

.panel-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--warm-gray);
  margin-bottom: 16px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}

/* Precise slider */
.slider-container {
  position: relative;
  padding-bottom: 28px;
}

.track-labels {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  display: flex;
  justify-content: space-between;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: var(--warm-gray);
}

input[type=range] {
  -webkit-appearance: none;
  width: 100%;
  height: 8px;
  border-radius: 4px;
  outline: none;
  cursor: pointer;
  background: var(--bg2);
  border: 1px solid var(--border);
}

input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 24px; height: 24px;
  border-radius: 50%;
  background: var(--choc);
  border: 3px solid var(--cream);
  box-shadow: 0 2px 8px rgba(61,28,0,0.4);
  cursor: grab;
  transition: transform 0.1s;
}

input[type=range]:active::-webkit-slider-thumb {
  cursor: grabbing;
  transform: scale(1.15);
}

/* Zone indicator */
.zone-bar {
  width: 100%;
  height: 10px;
  border-radius: 5px;
  margin-top: 10px;
  background: linear-gradient(to right,
    #2471A3 0%, #2471A3 20%,
    #1E8449 20%, #1E8449 40%,
    #B8860B 40%, #B8860B 68%,
    #E67E22 68%, #E67E22 84%,
    #C0392B 84%, #C0392B 100%
  );
  position: relative;
}

.zone-cursor {
  position: absolute;
  top: -4px;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: white;
  border: 3px solid var(--choc);
  transform: translateX(-50%);
  transition: left 0.4s cubic-bezier(0.34,1.3,0.64,1);
  box-shadow: 0 2px 6px rgba(0,0,0,0.2);
}

/* Presets */
.preset-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.preset-btn {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 8px;
  cursor: pointer;
  text-align: center;
  transition: all 0.18s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.preset-btn:hover {
  background: var(--choc);
  color: var(--cream);
  border-color: var(--choc);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(61,28,0,0.25);
}

.preset-btn .p-temp {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  font-weight: 600;
  color: var(--choc);
  transition: color 0.18s;
}

.preset-btn:hover .p-temp { color: #F5D78E; }

.preset-btn .p-label {
  font-size: 10px;
  color: var(--warm-gray);
  letter-spacing: 0.5px;
  transition: color 0.18s;
}

.preset-btn:hover .p-label { color: rgba(245,215,142,0.7); }

/* Phase table */
.phase-table {
  width: 100%;
  border-collapse: collapse;
}

.phase-table tr {
  border-bottom: 1px solid var(--border);
  transition: background 0.2s;
  cursor: pointer;
}

.phase-table tr:last-child { border-bottom: none; }

.phase-table tr.current-phase { background: rgba(184,134,11,0.1); }

.phase-table td {
  padding: 11px 8px;
  font-size: 0.85rem;
  vertical-align: middle;
}

.phase-table .td-color {
  width: 32px;
}

.color-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  display: inline-block;
}

.phase-table .td-temp {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--warm-gray);
  width: 80px;
}

.phase-table .td-name {
  font-weight: 700;
  color: var(--choc);
}

.phase-table .td-note {
  font-size: 11px;
  color: var(--warm-gray);
  font-style: italic;
}

.phase-table .td-status {
  text-align: right;
}

.status-pill {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 1px;
  font-weight: 600;
  opacity: 0;
  transition: opacity 0.3s;
}

tr.current-phase .status-pill { opacity: 1; }

/* ══════════════════════════════
   PAGE 2: HOW IT WORKS
══════════════════════════════ */
.how-page {
  max-width: 860px;
  margin: 0 auto;
  padding: 50px 40px 80px;
}

.how-page h2 {
  font-family: 'Libre Baskerville', serif;
  font-size: 2rem;
  color: var(--choc);
  margin-bottom: 8px;
}

.how-page .lead {
  color: var(--warm-gray);
  font-size: 1.05rem;
  line-height: 1.7;
  margin-bottom: 48px;
  font-style: italic;
  border-left: 3px solid var(--gold);
  padding-left: 16px;
}

/* Principle section */
.principle-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: center;
  margin-bottom: 60px;
}

.principle-section.flip { direction: rtl; }
.principle-section.flip > * { direction: ltr; }

.principle-text h3 {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.25rem;
  color: var(--choc);
  margin-bottom: 12px;
}

.principle-text p {
  font-size: 0.93rem;
  line-height: 1.75;
  color: #3a2a18;
}

.principle-text .highlight-box {
  background: rgba(184,134,11,0.1);
  border-left: 3px solid var(--gold);
  padding: 10px 14px;
  border-radius: 0 8px 8px 0;
  margin-top: 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--choc);
  line-height: 1.6;
}

/* SVG diagrams */
.diagram-box {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px;
  box-shadow: 0 2px 16px rgba(61,28,0,0.07);
  text-align: center;
}

.diagram-box svg {
  width: 100%;
  height: auto;
}

/* Steps */
.steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 60px;
}

.step {
  display: grid;
  grid-template-columns: 60px 1fr;
  gap: 0;
  position: relative;
}

.step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 29px;
  top: 52px;
  bottom: 0;
  width: 2px;
  background: var(--border);
}

.step-num {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 2px;
}

.step-circle {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: var(--choc);
  color: #F5D78E;
  font-family: 'JetBrains Mono', monospace;
  font-weight: 600;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.step-body {
  padding: 0 0 36px 20px;
}

.step-body h4 {
  font-family: 'Libre Baskerville', serif;
  font-size: 1rem;
  color: var(--choc);
  margin-bottom: 6px;
  padding-top: 4px;
}

.step-body p {
  font-size: 0.88rem;
  color: #4a3a28;
  line-height: 1.7;
}

/* Molecule visual */
.molecule-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
  margin: 20px 0;
}

.molecule-card {
  background: var(--cream);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 20px;
  text-align: center;
  flex: 1;
  min-width: 130px;
  box-shadow: 0 2px 10px rgba(61,28,0,0.06);
}

.molecule-card .m-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--choc);
  margin-bottom: 4px;
}

.molecule-card .m-temp {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 4px;
}

.molecule-card .m-desc {
  font-size: 11px;
  color: var(--warm-gray);
  font-style: italic;
}

.arrow-mid {
  font-size: 1.4rem;
  color: var(--gold);
  font-weight: bold;
}

/* Section divider */
.section-sep {
  border: none;
  border-top: 1px solid var(--border);
  margin: 48px 0;
}

.section-title {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.4rem;
  color: var(--choc);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ── ANIMATIONS ── */
@keyframes blink {
  0%,100% { opacity:1; }
  50% { opacity:0.3; }
}

@keyframes mercury-rise {
  from { height: 0; }
  to { height: var(--target-h); }
}

@media (max-width: 700px) {
  .thermo-layout { grid-template-columns: 1fr; }
  .principle-section { grid-template-columns: 1fr; }
  .principle-section.flip { direction: ltr; }
  .preset-grid { grid-template-columns: repeat(2,1fr); }
  nav { padding: 0 16px; }
  .thermo-page, .how-page { padding: 24px 16px 60px; }
}
</style>
</head>
<body>

<nav>
  <div class="nav-brand">
    <div class="dot"></div>
    ÇikoTerm Purno
  </div>
  <div class="tab-bar">
    <button class="tab-btn active" onclick="showPage('thermo', this)">Termometre</button>
    <button class="tab-btn" onclick="showPage('how', this)">Nasıl Çalışır?</button>
  </div>
</nav>

<div id="page-thermo" class="page active">
<div class="thermo-page">

  <div class="page-header">
    <h2>Çikolata Kristalizasyon Termometresi</h2>
    <p>Je Pète'nin mutfak laboratuvarı — doğru sıcaklık, mükemmel çikolata</p>
  </div>

  <div class="thermo-layout">

    <div class="thermo-card">
      <div class="thermo-title">Ölçüm Cihazı</div>

      <div class="big-temp">
        <span id="tempVal">27.0</span><span class="unit"> °C</span>
      </div>

      <div class="thermo-svg-wrap">
        <svg id="thermoSVG" viewBox="0 0 120 340" xmlns="http://www.w3.org/2000/svg">
          <rect x="50" y="20" width="20" height="240" rx="10" fill="#e8e0d0" stroke="#c8b89a" stroke-width="1.5"/>

          <clipPath id="tubeClip">
            <rect x="53" y="22" width="14" height="236" rx="8"/>
          </clipPath>

          <g clip-path="url(#tubeClip)">
            <rect x="53" y="22"  width="14" height="48"  fill="#2471A3" opacity="0.25"/>  <rect x="53" y="70"  width="14" height="48"  fill="#1E8449" opacity="0.25"/>  <rect x="53" y="118" width="14" height="67"  fill="#B8860B" opacity="0.25"/>  <rect x="53" y="185" width="14" height="40"  fill="#E67E22" opacity="0.25"/>  <rect x="53" y="225" width="14" height="33"  fill="#C0392B" opacity="0.25"/>  </g>

          <g clip-path="url(#tubeClip)">
            <rect id="mercuryFill" x="55" y="258" width="10" height="0" rx="4"
              fill="url(#mercGrad)" transform="scale(1,-1) translate(0,-518)"/>
          </g>

          <defs>
            <linearGradient id="mercGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#F5D78E"/>
              <stop offset="60%" stop-color="#B8860B"/>
              <stop offset="100%" stop-color="#6B2D00"/>
            </linearGradient>
          </defs>

          <rect x="50" y="20" width="20" height="240" rx="10" fill="none" stroke="#a89070" stroke-width="1.5"/>

          <line x1="42" y1="24"  x2="50" y2="24"  stroke="#8A7A6A" stroke-width="1"/>
          <text x="39" y="27" text-anchor="end" font-family="JetBrains Mono" font-size="8" fill="#8A7A6A">60°</text>
          <line x1="45" y1="48"  x2="50" y2="48"  stroke="#8A7A6A" stroke-width="0.7"/>
          <text x="42" y="51" text-anchor="end" font-family="JetBrains Mono" font-size="7" fill="#aaa">50°</text>
          <line x1="42" y1="72"  x2="50" y2="72"  stroke="#8A7A6A" stroke-width="1"/>
          <text x="39" y="75" text-anchor="end" font-family="JetBrains Mono" font-size="8" fill="#8A7A6A">40°</text>
          <line x1="45" y1="84"  x2="50" y2="84"  stroke="#B8860B" stroke-width="0.7"/>
          <text x="42" y="87" text-anchor="end" font-family="JetBrains Mono" font-size="7" fill="#B8860B">35°</text>
          <line x1="44" y1="100" x2="70" y2="100" stroke="#B8860B" stroke-width="0.5" stroke-dasharray="2,2"/>
          <line x1="42" y1="120" x2="50" y2="120" stroke="#8A7A6A" stroke-width="1"/>
          <text x="39" y="123" text-anchor="end" font-family="JetBrains Mono" font-size="8" fill="#8A7A6A">30°</text>
          <line x1="44" y1="124" x2="70" y2="124" stroke="#B8860B" stroke-width="0.5" stroke-dasharray="2,2"/>
          <line x1="42" y1="168" x2="50" y2="168" stroke="#8A7A6A" stroke-width="1"/>
          <text x="39" y="171" text-anchor="end" font-family="JetBrains Mono" font-size="8" fill="#8A7A6A">20°</text>
          <line x1="42" y1="216" x2="50" y2="216" stroke="#8A7A6A" stroke-width="1"/>
          <text x="39" y="219" text-anchor="end" font-family="JetBrains Mono" font-size="8" fill="#8A7A6A">10°</text>

          <text x="74" y="44"  font-family="JetBrains Mono" font-size="7" fill="#C0392B">ERİME</text>
          <text x="74" y="85"  font-family="JetBrains Mono" font-size="7" fill="#E67E22">SICAK</text>
          <text x="74" y="122" font-family="JetBrains Mono" font-size="7" fill="#B8860B">TEMPER</text>
          <text x="74" y="165" font-family="JetBrains Mono" font-size="7" fill="#1E8449">KRİSTAL</text>
          <text x="74" y="215" font-family="JetBrains Mono" font-size="7" fill="#2471A3">SERT</text>

          <circle cx="60" cy="280" r="18" fill="url(#bulbGrad)" stroke="#a89070" stroke-width="1.5"/>
          <circle cx="60" cy="280" r="18" fill="none" stroke="#e8d8b0" stroke-width="0.5" opacity="0.5"/>
          <circle cx="54" cy="274" r="4" fill="white" opacity="0.25"/>

          <defs>
            <radialGradient id="bulbGrad" cx="40%" cy="35%" r="65%">
              <stop offset="0%" stop-color="#F5D78E" id="bulbLight"/>
              <stop offset="100%" stop-color="#6B2D00" id="bulbDark"/>
            </radialGradient>
          </defs>

          <polygon id="needleMarker" points="48,258 42,254 42,262" fill="#1C1008" opacity="0.8"/>
        </svg>
      </div>

      <div class="phase-chip" id="phaseChip">
        <div class="chip-dot" id="chipDot"></div>
        <span id="chipText">KRİSTALİZASYON</span>
      </div>

    </div>

    <div class="controls-area">

      <div class="panel">
        <div class="panel-label">Sıcaklık Ayarı</div>
        <div class="slider-container">
          <input type="range" id="tempSlider" min="10" max="60" value="27" step="0.5">
          <div class="zone-bar">
            <div class="zone-cursor" id="zoneCursor"></div>
          </div>
          <div class="track-labels" style="margin-top:4px">
            <span>10°C</span><span>20°C</span><span>30°C</span><span>40°C</span><span>50°C</span><span>60°C</span>
          </div>
        </div>
      </div>

      <div class="panel">
        <div class="panel-label">Hızlı Sıcaklık Noktaları</div>
        <div class="preset-grid">
          <div class="preset-btn" onclick="setTemp(16)">
            <div class="p-temp">16°C</div>
            <div class="p-label">Buzdolabı</div>
          </div>
          <div class="preset-btn" onclick="setTemp(22)">
            <div class="p-temp">22°C</div>
            <div class="p-label">Soğuma</div>
          </div>
          <div class="preset-btn" onclick="setTemp(31.5)">
